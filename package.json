{
  "name": "woven-model-purchase-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/design-system",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/design-system && npm run build -w packages/backend && npm run build -w packages/frontend",
    "db:push": "npm run prisma:push -w packages/backend",
    "db:seed": "npm run prisma:seed -w packages/backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
