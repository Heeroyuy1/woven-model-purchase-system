generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Default DATABASE_URL: file:./dev.db

model Customer {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  company   String?
  phone     String?
  role      String   @default("customer") // customer, admin, super_admin
  isActive        Boolean  @default(true)
  emailVerified   Boolean  @default(false)
  licensingUserId Int?     // User ID on the licensing server
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  licenses     License[]
  cartItems    CartItem[]
  reviews      ProductReview[]
  supportReqs  SupportRequest[]
  subscriptions Subscription[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model Product {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  shortDescription String?
  overview         String?
  version          String   @default("1.0.0")
  category         String?  // AI_APPS, TRADING, AUTOMATION, ENTERPRISE, UTILITIES, INTERNAL
  pricing          Float    @default(0)
  licenseType      String   @default("perpetual") // perpetual, subscription, trial, developer, enterprise
  trialAvailable   Boolean  @default(false)
  trialDays        Int?     @default(14)
  platformSupport  String?  // JSON array of supported OS
  systemRequirements String? // JSON
  features         String?  // JSON array of features
  screenshots      String?  // JSON array of URLs
  videos           String?  // JSON array of URLs
  faqs             String?  // JSON array of {q, a} objects
  documentationUrl String?
  supportInfo      String?  // JSON
  releaseNotes     String?  // JSON
  versionHistory   String?  // JSON
  active           Boolean  @default(true)
  metadata         String?  // JSON blob for extensibility
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  licensingProductId Int?   // Foreign key to licensing-server Product.id
  licenses         License[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  reviews          ProductReview[]
}

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  status          String   @default("pending") // pending, confirmed, processing, completed, cancelled, refunded
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  total           Float    @default(0)
  currency        String   @default("USD")
  couponCode      String?
  notes           String?
  billingAddress  String?  // JSON
  shippingAddress String?  // JSON
  paymentMethod   String?  // stripe, paypal
  paymentId       String?  // Payment gateway transaction ID
  paidAt          DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  items      OrderItem[]
  invoices   Invoice[]
  payments   Payment[]
  licenses   License[]
  events     OrderEvent[]
}

model OrderItem {
  id          String  @id @default(uuid())
  productName String
  productCode String
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  totalPrice  Float   @default(0)
  licenseType String?

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  licenses License[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  status        String   @default("pending") // pending, paid, overdue, cancelled, refunded
  total         Float    @default(0)
  taxAmount     Float    @default(0)
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payments  Payment[]
}

model Payment {
  id             String   @id @default(uuid())
  method         String   // stripe, paypal
  transactionId  String?
  amount         Float    @default(0)
  currency       String   @default("USD")
  status         String   @default("pending") // pending, succeeded, failed, refunded
  gatewayResponse String? // JSON raw response from gateway
  createdAt      DateTime @default(now())

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

model License {
  id                String   @id @default(uuid())
  licenseKey        String   @unique
  licenseType       String   @default("perpetual")
  status            String   @default("active") // active, expired, revoked, suspended, pending
  activationLimit   Int      @default(1)
  currentActivations Int     @default(0)
  expirationDate    DateTime?
  perpetual         Boolean  @default(false)
  metadata          String?  // JSON
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  licensingLicenseId Int?    // Reference to licensing-server License.id

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  productId   String
  product     Product   @relation(fields: [productId], references: [id])

  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])

  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])

  subscription Subscription?
}

model Subscription {
  id            String   @id @default(uuid())
  status        String   @default("active") // active, paused, cancelled, expired
  startDate     DateTime @default(now())
  endDate       DateTime?
  cancelledAt   DateTime?
  autoRenew     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  licenseId  String   @unique
  license    License  @relation(fields: [licenseId], references: [id])
}

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  description  String?
  discountType String   // percentage, fixed
  discountValue Float
  minOrderAmount Float?
  maxUses      Int?
  usedCount    Int      @default(0)
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OrderEvent {
  id        String   @id @default(uuid())
  event     String   // created, paid, license_generated, email_sent, completed, refunded
  details   String?  // JSON with event-specific data
  createdAt DateTime @default(now())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProductReview {
  id        String   @id @default(uuid())
  rating    Int      @default(5)
  title     String?
  content   String?
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
}

model SupportRequest {
  id        String   @id @default(uuid())
  subject   String
  message   String
  status    String   @default("open") // open, in_progress, resolved, closed
  priority  String   @default("normal") // low, normal, high, urgent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique // order_confirmation, license_delivery, thank_you, ...
  subject   String
  htmlBody  String
  variables String?  // JSON array of expected variable names
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  template  String?
  status    String   // sent, failed, bounced
  error     String?
  sentAt    DateTime @default(now())

  orderId   String?
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // order_completed, payment_received, license_generated, subscription_renewal, license_expiring, product_update, security_update
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  resourceType String
  resourceId   String?
  details      String?  // JSON
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  userId String?
  user   Customer? @relation(fields: [userId], references: [id])
}

model Download {
  id        String   @id @default(uuid())
  productId String
  productCode String
  version   String
  fileName  String
  fileSize  Int?
  url       String
  downloadCount Int @default(0)
  createdAt DateTime @default(now())
}
