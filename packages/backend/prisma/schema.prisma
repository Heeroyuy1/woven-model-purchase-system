generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  @@map("purchase_customers")
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  company   String?
  phone     String?
  role      String   @default("customer")
  isActive        Boolean  @default(true)
  emailVerified   Boolean  @default(false)
  licensingUserId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders       Order[]
  licenses     License[]
  cartItems    CartItem[]
  reviews      ProductReview[]
  supportReqs  SupportRequest[]
  subscriptions Subscription[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model Product {
  @@map("purchase_products")
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  shortDescription String?
  overview         String?
  version          String   @default("1.0.0")
  category         String?
  pricing          Float    @default(0)
  licenseType      String   @default("perpetual")
  trialAvailable   Boolean  @default(false)
  trialDays        Int?     @default(14)
  platformSupport  String?
  systemRequirements String?
  features         String?
  screenshots      String?
  videos           String?
  faqs             String?
  documentationUrl String?
  supportInfo      String?
  releaseNotes     String?
  versionHistory   String?
  active           Boolean  @default(true)
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  licensingProductId Int?
  licenses         License[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  reviews          ProductReview[]
}

model CartItem {
  @@map("purchase_cart_items")
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@unique([customerId, productId])
}

model Order {
  @@map("purchase_orders")
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  status          String   @default("pending")
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  total           Float    @default(0)
  currency        String   @default("USD")
  couponCode      String?
  notes           String?
  billingAddress  String?
  shippingAddress String?
  paymentMethod   String?
  paymentId       String?
  paidAt          DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  invoices   Invoice[]
  payments   Payment[]
  licenses   License[]
  events     OrderEvent[]
}

model OrderItem {
  @@map("purchase_order_items")
  id          String  @id @default(uuid())
  productName String
  productCode String
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  totalPrice  Float   @default(0)
  licenseType String?
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  licenses License[]
}

model Invoice {
  @@map("purchase_invoices")
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  status        String   @default("pending")
  total         Float    @default(0)
  taxAmount     Float    @default(0)
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payments  Payment[]
}

model Payment {
  @@map("purchase_payments")
  id             String   @id @default(uuid())
  method         String
  transactionId  String?
  amount         Float    @default(0)
  currency       String   @default("USD")
  status         String   @default("pending")
  gatewayResponse String?
  createdAt      DateTime @default(now())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

model License {
  @@map("purchase_licenses")
  id                String   @id @default(uuid())
  licenseKey        String   @unique
  licenseType       String   @default("perpetual")
  status            String   @default("active")
  activationLimit   Int      @default(1)
  currentActivations Int     @default(0)
  expirationDate    DateTime?
  perpetual         Boolean  @default(false)
  metadata          String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  licensingLicenseId Int?
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  subscription Subscription?
}

model Subscription {
  @@map("purchase_subscriptions")
  id            String   @id @default(uuid())
  status        String   @default("active")
  startDate     DateTime @default(now())
  endDate       DateTime?
  cancelledAt   DateTime?
  autoRenew     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  licenseId  String   @unique
  license    License  @relation(fields: [licenseId], references: [id])
}

model Coupon {
  @@map("purchase_coupons")
  id           String   @id @default(uuid())
  code         String   @unique
  description  String?
  discountType String
  discountValue Float
  minOrderAmount Float?
  maxUses      Int?
  usedCount    Int      @default(0)
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OrderEvent {
  @@map("purchase_order_events")
  id        String   @id @default(uuid())
  event     String
  details   String?
  createdAt DateTime @default(now())
  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProductReview {
  @@map("purchase_product_reviews")
  id        String   @id @default(uuid())
  rating    Int      @default(5)
  title     String?
  content   String?
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  @@unique([customerId, productId])
}

model SupportRequest {
  @@map("purchase_support_requests")
  id        String   @id @default(uuid())
  subject   String
  message   String
  status    String   @default("open")
  priority  String   @default("normal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model EmailTemplate {
  @@map("purchase_email_templates")
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  htmlBody  String
  variables String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  @@map("purchase_email_logs")
  id        String   @id @default(uuid())
  to        String
  subject   String
  template  String?
  status    String
  error     String?
  sentAt    DateTime @default(now())
  orderId   String?
}

model Notification {
  @@map("purchase_notifications")
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model AuditLog {
  @@map("purchase_audit_logs")
  id           String   @id @default(uuid())
  action       String
  resourceType String
  resourceId   String?
  details      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  userId String?
  user   Customer? @relation(fields: [userId], references: [id])
}

model Download {
  @@map("purchase_downloads")
  id        String   @id @default(uuid())
  productId String
  productCode String
  version   String
  fileName  String
  fileSize  Int?
  url       String
  downloadCount Int @default(0)
  createdAt DateTime @default(now())
}
